    "verify:phase5:pilot-runtime": "node scripts/phase5-pilot-runtime-verify.mjs",
    "verify:phase6:runtime": "node scripts/phase6-workflow-runtime-readiness.mjs",
    "verify:phase6:smoke": "node scripts/phase6-workflow-smoke.mjs",
    "verify:phase6:staging": "node scripts/phase6-staging-runtime-verify.mjs",
    "verify:phase7:observability": "node scripts/phase7-observability-verify.mjs"
