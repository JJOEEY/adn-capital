{
  "name": "adn-ai-bot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "check:encoding": "node scripts/check-encoding.mjs",
