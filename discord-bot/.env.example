# ===== Discord =====
DISCORD_TOKEN=            # Bot token (Developer Portal → Bot → Reset Token)
DISCORD_CLIENT_ID=        # Application ID (Developer Portal → General Information)
DISCORD_GUILD_ID=         # ID server test (bật Developer Mode, chuột phải server → Copy ID)

# ===== ADN backend (gọi nội bộ qua docker network) =====
ADN_API_BASE=http://adn-web:3000
INTERNAL_API_KEY=         # cho endpoint nội bộ (brief-image). Lấy từ env web.

# ===== Kênh auto-post (chuột phải kênh → Copy ID) =====
CHANNEL_SIGNALS=          # kênh đẩy tín hiệu mua/bán (tín-hiệu)
CHANNEL_BRIEF=            # kênh đẩy bản tin sáng/EOD (bảng-tin-hằng-ngày)

# ===== Kênh chỉ định cho lệnh (gate "mỗi nơi 1 công cụ") — trống = mọi nơi =====
CH_AIDEN=                 # kênh aiden-chat (chat với AIDEN)
CH_STOCK=                 # kênh stock-chat (gồm /stock /rank /art /ptkt /ptcb /tintuc /atc)

# Bật AIDEN trả lời MỌI tin ở aiden-chat (không cần @tag).
# CHỈ đặt =1 SAU khi đã bật "Message Content Intent" trong Developer Portal (Bot → Privileged Gateway Intents),
# nếu không bot sẽ crash "Used disallowed intents".
AIDEN_LISTEN=

# ===== Roles theo tier (gate tính năng cao cấp) =====
ROLE_PREMIUM=
ROLE_VIP=
