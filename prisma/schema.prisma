generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// ═══ Ghi chú: SQLite không hỗ trợ enum, dùng String thay thế ═══
// systemRole: ADMIN | USER  (quyền hệ thống)
// subscriptionTier: FREE | VIP | PREMIUM  (gói cước, tính từ vipUntil)
// SignalType: SIEU_CO_PHIEU | TRUNG_HAN | DAU_CO
// TradeAction: BUY | SELL

// ═══════════════════════════════════════════════════════════════════
//  MODEL NEXTAUTH – Bắt buộc cho @auth/prisma-adapter
// ═══════════════════════════════════════════════════════════════════

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ═══════════════════════════════════════════════════════════════════
//  MODEL NGHIỆP VỤ
// ═══════════════════════════════════════════════════════════════════

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  password        String?
  role            String           @default("FREE")       // subscription: FREE | VIP (giữ tương thích)
  systemRole      String           @default("USER")       // quyền hệ thống: ADMIN | USER
  vipUntil        DateTime?
  name            String?
  image           String?
  emailVerified   DateTime?
  chatCount       Int              @default(0)
  dnseId          String?          @unique
  dnseVerified    Boolean          @default(false)
  dnseAppliedAt   DateTime?
  initialJournalNAV Float?                                // Số dư vốn ban đầu của Nhật ký (VNĐ)
  enableAIReview  Boolean          @default(true)          // Bật/Tắt AI đánh giá tâm lý hàng tuần
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  accounts       Account[]
  sessions       Session[]
  chats          Chat[]
  paymentOrders  PaymentOrder[]
  tradingJournal TradingJournal[]
  pushSubscriptions PushSubscription[]
  notifications  Notification[]
  articles       Article[]
  grantedEntitlements AdminEntitlementGrant[] @relation("EntitlementGrantedBy")
  receivedEntitlements AdminEntitlementGrant[] @relation("EntitlementTargetUser")
}

model AdminEntitlementGrant {
  id               String   @id @default(cuid())
  targetUserId     String
  badge            String   // FREE | VIP | PREMIUM
  durationDays     Int
  grantedByAdminId String
  grantedAt        DateTime @default(now())
  expiresAt        DateTime
  status           String   @default("ACTIVE") // ACTIVE | EXPIRED | REVOKED
  note             String?
  createdAt        DateTime @default(now())

  targetUser       User @relation("EntitlementTargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)
  grantedByAdmin   User @relation("EntitlementGrantedBy", fields: [grantedByAdminId], references: [id], onDelete: Cascade)

  @@index([targetUserId, createdAt])
  @@index([targetUserId, expiresAt])
  @@index([grantedByAdminId, createdAt])
}

model PaymentOrder {
  id            String   @id @default(cuid())
  userId        String
  orderCode     String   @unique
  planId        String   @default("1m")
  amount        Int
  description   String
  paymentLinkId String?
  checkoutUrl   String?
  status        String   @default("PENDING")
  expiresAt     DateTime?
  paidAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Chat {
  id        String   @id @default(cuid())
  userId    String?
  message   String
  role      String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Signal {
  id            String   @id @default(cuid())
  ticker        String
  type          String              // SIEU_CO_PHIEU | TRUNG_HAN | DAU_CO
  status        String   @default("RADAR")  // RADAR | ACTIVE | CLOSED
  tier          String   @default("NGAN_HAN") // LEADER | TRUNG_HAN | NGAN_HAN
  entryPrice    Float
  target        Float?              // Giá chốt lời
  stoploss      Float?              // Giá cắt lỗ
  closePrice    Float?              // Giá đóng vị thế
  currentPrice  Float?              // Giá hiện tại (cập nhật bởi lifecycle worker)
  currentPnl    Float?              // Lãi/lỗ % realtime (ACTIVE)
  navAllocation Float    @default(0) // % NAV phân bổ (0-100)
  triggerSignal String?             // Lý do kích hoạt (VSA reason)
  aiReasoning   String?             // AI Broker nhận xét
  reason        String?             // Chi tiết kỹ thuật
  pnl           Float?              // Lãi/lỗ % khi CLOSED
  closedReason  String?             // Lý do đóng: "Chốt lời Target" | "Cắt lỗ" | "AI Exit"
  winRate       Float?              // Seasonality win rate tháng hiện tại
  sharpeRatio   Float?              // Seasonality sharpe ratio tháng hiện tại
  closedAt      DateTime?           // Ngày đóng vị thế
  rrRatio       String?             // Tỷ lệ R/R (e.g. "1:2.5")
  holdingAction String?             // Thông báo gồng lãi / Trailing Stop
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  @@index([ticker, createdAt])
  @@index([status, createdAt])
}

model TradingJournal {
  id             String      @id @default(cuid())
  userId         String
  ticker         String
  action         String                                    // BUY | SELL
  price          Float
  quantity       Int
  psychology     String                                    // Legacy: free text (backward compat)
  psychologyTag  String?                                   // Enum: Có kế hoạch | Tự tin | FOMO | Theo room | Cảm tính | Hoảng loạn
  tradeReason    String?                                   // Lý do chi tiết vào/ra lệnh
  tradeDate      DateTime?                                 // Ngày giao dịch (cho phép lùi ngày)
  createdAt      DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tradeDate])
  @@index([userId, ticker, action])
}

model CourseRegistration {
  id        String   @id @default(cuid())
  name      String
  zalo      String
  status    String   @default("CHUA_MO_TK") // DA_MO_TK | CHUA_MO_TK
  vipStatus String   @default("NONE")       // NONE | ACTIVE | EXPIRED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MarginConsultation {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String
  product     String   @default("ky-quy")  // ky-quy | mua-nhanh-ban-nhanh
  tickers     String?  // comma-separated mã CK (optional)
  marginRatio String?  // Tỉ lệ ký quỹ (only for ky-quy)
  loanAmount  String
  status      String   @default("NEW")  // NEW | CONTACTED | DONE
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // signal_10h | signal_1130 | ... | ai_weekly_review
  title     String
  content   String   // markdown content
  userId    String?  // NULL = global notification, non-NULL = private 1-1 cho user cụ thể
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([userId, createdAt])
}

// ═══════════════════════════════════════════════════════════════════
//  MODEL TỰ ĐỘNG HÓA — Cron, Báo cáo, Knowledge Base
// ═══════════════════════════════════════════════════════════════════

model MarketReport {
  id        String   @id @default(cuid())
  type      String   // morning_brief | eod_brief | prop_trading | intraday_update
  title     String
  content   String   // markdown / JSON content
  rawData   String?  // JSON raw data từ FiinQuant/CafeF/VNDirect
  metadata  String?  // JSON metadata (index values, breadth, etc.)
  createdAt DateTime @default(now())

  @@index([type, createdAt])
}

model CronLog {
  id         String   @id @default(cuid())
  cronName   String   // morning_brief | eod_brief | prop_trading | intraday | signal_scan
  status     String   // success | error | skipped
  message    String?
  duration   Int?     // milliseconds
  resultData String?  // JSON kết quả tóm tắt
  createdAt  DateTime @default(now())

  @@index([cronName, createdAt])
}

model ChatKnowledge {
  id        String   @id @default(cuid())
  category  String   // ta_rules | fa_rules | risk_management | market_regime | trading_psychology | glossary
  title     String
  content   String   // nội dung quy tắc / kiến thức
  priority  Int      @default(0) // cao hơn = ưu tiên inject trước
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, priority])
}

model PropTrading {
  id            String   @id @default(cuid())
  date          String   // YYYY-MM-DD
  totalBuy      Float    @default(0)  // tỷ VNĐ
  totalSell     Float    @default(0)
  netValue      Float    @default(0)  // mua ròng / bán ròng
  topBuy        String?  // JSON array: [{ticker, value}]
  topSell       String?  // JSON array: [{ticker, value}]
  rawData       String?  // JSON raw data
  createdAt     DateTime @default(now())

  @@unique([date])
  @@index([date])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model AvatarUpload {
  id        String   @id @default(cuid())
  userId    String
  filename  String
  filePath  String   // đường dẫn filesystem tới file ảnh
  url       String   // URL truy cập: /api/user/avatar/[filename]
  mimeType  String?
  size      Int?     // bytes
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Lịch sử gửi tín hiệu Telegram — tránh spam duplicate
model SignalHistory {
  id         String   @id @default(cuid())
  ticker     String
  signalType String   // SIEU_CO_PHIEU | TRUNG_HAN | DAU_CO
  sentDate   String   // YYYY-MM-DD
  createdAt  DateTime @default(now())

  @@unique([ticker, signalType, sentDate])
  @@index([sentDate])
}

model GuideCategory {
  id        String         @id @default(cuid())
  title     String
  slug      String         @unique
  sortOrder Int            @default(0)
  sections  GuideSection[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([sortOrder])
}

model GuideSection {
  id         String        @id @default(cuid())
  title      String
  slug       String
  content    String        @db.Text
  sortOrder  Int           @default(0)
  published  Boolean       @default(true)
  categoryId String
  category   GuideCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([categoryId, slug])
  @@index([categoryId, sortOrder])
}

// ═══════════════════════════════════════════════════════════════════
//  CHANGELOG — Lịch sử chỉnh sửa hệ thống
// ═══════════════════════════════════════════════════════════════════

model Changelog {
  id          String   @id @default(cuid())
  component   String   // PricingSection, SignalMap, ...
  action      String   // UPDATE_FEATURES, ADD_PLAN, ...
  description String   // Mô tả chi tiết thay đổi
  diff        String?  // JSON diff / notes
  author      String   @default("system")
  createdAt   DateTime @default(now())

  @@index([component, createdAt])
}

// ═══════════════════════════════════════════════════════════════════
//  CMS — Quản trị Nội dung (Articles & Categories)
// ═══════════════════════════════════════════════════════════════════
// systemRole mở rộng: ADMIN | USER | WRITER
// WRITER = full quyền VIP 3 tháng + quyền tạo bài viết

model Category {
  id        String    @id @default(cuid())
  name      String    @unique          // Thị trường, Quốc tế, Bất động sản...
  slug      String    @unique
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  articles Article[]

  @@index([slug])
  @@index([sortOrder])
}

model Article {
  id            String   @id @default(cuid())
  title         String
  originalTitle String?                          // Tiêu đề gốc cào được (đối chiếu AI viết lại)
  slug          String   @unique
  content       String                           // Rich text / HTML
  excerpt       String?                          // Mô tả ngắn
  aiSummary     String?                          // AI tóm tắt ngắn đầu bài
  authorId      String
  sourceUrl     String?                          // Nguồn gốc bài báo nếu kéo về
  imageUrl      String?                          // Ảnh đại diện bài viết
  pdfUrl        String?                          // Link tải báo cáo Research PDF từ CTCK
  status        String   @default("DRAFT")       // DRAFT | PENDING_APPROVAL | PUBLISHED | REJECTED
  tags          String   @default("[]")          // JSON array: ["Tin tức", "Vĩ mô", "Tích cực"]
  sentiment     String?                          // Tích cực | Tiêu cực | Trung tính
  categoryId    String?
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([status, publishedAt])
  @@index([categoryId, publishedAt])
  @@index([authorId, createdAt])
  @@index([slug])
}
model AiInsightCache {
  id        String   @id @default(cuid())
  ticker    String
  tabType   String   // PTKT | PTCB
  content   String
  updatedAt DateTime @updatedAt

  @@unique([ticker, tabType])
  @@index([ticker])
}

// Runtime settings controlled from Admin UI (no server restart needed)
model SystemSetting {
  key       String   @id   // e.g. "IS_MOCK_MODE"
  value     String         // stored as string; "true" | "false" | numeric etc.
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════
//  AI ANALYSIS CACHE — 4 Lõi Tư Vấn Đầu Tư
// ═══════════════════════════════════════════════════════════════════

// Cache phân tích kỹ thuật — hợp lệ khi giá chưa vỡ support/resistance
model AiTaCache {
  id         String   @id @default(cuid())
  ticker     String
  analysis   String   @db.Text
  mediaUrl   String?  @db.Text  // base64 chart từ mplfinance
  support    Float?
  resistance Float?
  signal     String?            // Bullish | Bearish | Neutral
  entryPrice Float?             // Giá hiện tại lúc generate
  createdAt  DateTime @default(now())

  @@index([ticker])
  @@index([ticker, createdAt])
}

// Cache phân tích cơ bản — hợp lệ cả ngày (FA ít thay đổi)
model AiFaCache {
  id        String   @id @default(cuid())
  ticker    String
  analysis  String   @db.Text
  quarter   String?            // VD: "Q1 2026"
  createdAt DateTime @default(now())

  @@index([ticker])
  @@index([ticker, createdAt])
}

// Cache phân tích tâm lý ATC — hợp lệ 1 ngày
model AiTamlyCache {
  id        String   @id @default(cuid())
  ticker    String
  date      String             // YYYY-MM-DD
  analysis  String   @db.Text
  createdAt DateTime @default(now())

  @@index([ticker, date])
}

