generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ═══ Ghi chú: SQLite không hỗ trợ enum, dùng String thay thế ═══
// UserRole: FREE | VIP
// SignalType: SIEU_CO_PHIEU | TRUNG_HAN | DAU_CO
// TradeAction: BUY | SELL

// ═══════════════════════════════════════════════════════════════════
//  MODEL NEXTAUTH – Bắt buộc cho @auth/prisma-adapter
// ═══════════════════════════════════════════════════════════════════

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ═══════════════════════════════════════════════════════════════════
//  MODEL NGHIỆP VỤ
// ═══════════════════════════════════════════════════════════════════

model User {
  id            String           @id @default(uuid())
  email         String           @unique
  password      String?
  role          String           @default("FREE")
  vipUntil      DateTime?
  name          String?
  image         String?
  emailVerified DateTime?
  chatCount     Int              @default(0)
  dnseId        String?          @unique
  dnseVerified  Boolean          @default(false)
  dnseAppliedAt DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  accounts       Account[]
  sessions       Session[]
  chats          Chat[]
  paymentOrders  PaymentOrder[]
  tradingJournal TradingJournal[]
  pushSubscriptions PushSubscription[]
}

model PaymentOrder {
  id            String   @id @default(cuid())
  userId        String
  orderCode     String   @unique
  planId        String   @default("1m")
  amount        Int
  description   String
  paymentLinkId String?
  checkoutUrl   String?
  status        String   @default("PENDING")
  expiresAt     DateTime?
  paidAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Chat {
  id        String   @id @default(cuid())
  userId    String?
  message   String
  role      String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Signal {
  id         String   @id @default(cuid())
  ticker     String
  type       String
  entryPrice Float
  reason     String?
  createdAt  DateTime @default(now())

  @@index([ticker, createdAt])
}

model TradingJournal {
  id         String      @id @default(cuid())
  userId     String
  ticker     String
  action     String
  price      Float
  quantity   Int
  psychology String
  createdAt  DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CourseRegistration {
  id        String   @id @default(cuid())
  name      String
  zalo      String
  status    String   @default("CHUA_MO_TK") // DA_MO_TK | CHUA_MO_TK
  vipStatus String   @default("NONE")       // NONE | ACTIVE | EXPIRED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MarginConsultation {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String
  product     String   @default("ky-quy")  // ky-quy | mua-nhanh-ban-nhanh
  tickers     String?  // comma-separated mã CK (optional)
  marginRatio String?  // Tỉ lệ ký quỹ (only for ky-quy)
  loanAmount  String
  status      String   @default("NEW")  // NEW | CONTACTED | DONE
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // signal_10h | signal_1130 | signal_14h | signal_1445 | market_17h | eod_19h | morning_8h | eod_15h | prop_19h | signal_5m
  title     String
  content   String   // markdown content
  createdAt DateTime @default(now())

  @@index([type, createdAt])
}

// ═══════════════════════════════════════════════════════════════════
//  MODEL TỰ ĐỘNG HÓA — Cron, Báo cáo, Knowledge Base
// ═══════════════════════════════════════════════════════════════════

model MarketReport {
  id        String   @id @default(cuid())
  type      String   // morning_brief | eod_brief | prop_trading | intraday_update
  title     String
  content   String   // markdown / JSON content
  rawData   String?  // JSON raw data từ FiinQuant/CafeF/VNDirect
  metadata  String?  // JSON metadata (index values, breadth, etc.)
  createdAt DateTime @default(now())

  @@index([type, createdAt])
}

model CronLog {
  id         String   @id @default(cuid())
  cronName   String   // morning_brief | eod_brief | prop_trading | intraday | signal_scan
  status     String   // success | error | skipped
  message    String?
  duration   Int?     // milliseconds
  resultData String?  // JSON kết quả tóm tắt
  createdAt  DateTime @default(now())

  @@index([cronName, createdAt])
}

model ChatKnowledge {
  id        String   @id @default(cuid())
  category  String   // ta_rules | fa_rules | risk_management | market_regime | trading_psychology | glossary
  title     String
  content   String   // nội dung quy tắc / kiến thức
  priority  Int      @default(0) // cao hơn = ưu tiên inject trước
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, priority])
}

model PropTrading {
  id            String   @id @default(cuid())
  date          String   // YYYY-MM-DD
  totalBuy      Float    @default(0)  // tỷ VNĐ
  totalSell     Float    @default(0)
  netValue      Float    @default(0)  // mua ròng / bán ròng
  topBuy        String?  // JSON array: [{ticker, value}]
  topSell       String?  // JSON array: [{ticker, value}]
  rawData       String?  // JSON raw data
  createdAt     DateTime @default(now())

  @@unique([date])
  @@index([date])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}
