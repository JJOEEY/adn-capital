generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ═══ Ghi chú: SQLite không hỗ trợ enum, dùng String thay thế ═══
// UserRole: FREE | VIP
// SignalType: SIEU_CO_PHIEU | TRUNG_HAN | DAU_CO
// TradeAction: BUY | SELL

// ═══════════════════════════════════════════════════════════════════
//  MODEL NEXTAUTH – Bắt buộc cho @auth/prisma-adapter
// ═══════════════════════════════════════════════════════════════════

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ═══════════════════════════════════════════════════════════════════
//  MODEL NGHIỆP VỤ
// ═══════════════════════════════════════════════════════════════════

model User {
  id            String           @id @default(uuid())
  email         String           @unique
  password      String?
  role          String           @default("FREE")
  vipUntil      DateTime?
  name          String?
  image         String?
  emailVerified DateTime?
  chatCount     Int              @default(0)
  dnseId        String?          @unique
  dnseVerified  Boolean          @default(false)
  dnseAppliedAt DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  accounts       Account[]
  sessions       Session[]
  chats          Chat[]
  paymentOrders  PaymentOrder[]
  tradingJournal TradingJournal[]
}

model PaymentOrder {
  id            String   @id @default(cuid())
  userId        String
  orderCode     String   @unique
  amount        Int
  description   String
  paymentLinkId String?
  checkoutUrl   String?
  status        String   @default("PENDING")
  expiresAt     DateTime?
  paidAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Chat {
  id        String   @id @default(cuid())
  userId    String?
  message   String
  role      String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Signal {
  id         String   @id @default(cuid())
  ticker     String
  type       String
  entryPrice Float
  reason     String?
  createdAt  DateTime @default(now())

  @@index([ticker, createdAt])
}

model TradingJournal {
  id         String      @id @default(cuid())
  userId     String
  ticker     String
  action     String
  price      Float
  quantity   Int
  psychology String
  createdAt  DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CourseRegistration {
  id        String   @id @default(cuid())
  name      String
  zalo      String
  status    String   @default("CHUA_MO_TK") // DA_MO_TK | CHUA_MO_TK
  vipStatus String   @default("NONE")       // NONE | ACTIVE | EXPIRED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
