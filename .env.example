# ============================================
# ADN Capital - Environment Variables Template
# Usage: cp .env.example .env
# ============================================

# -- DATABASE (PostgreSQL Docker) --
# DATABASE_URL runs through PgBouncer for pooled app traffic
DATABASE_URL="postgresql://adnuser:YOUR_DB_PASSWORD@pgbouncer:5432/adncapital?schema=public&pgbouncer=true"
# DIRECT_DATABASE_URL is for migrate/introspection/direct queries
DIRECT_DATABASE_URL="postgresql://adnuser:YOUR_DB_PASSWORD@db:5432/adncapital?schema=public"

POSTGRES_USER="adnuser"
POSTGRES_PASSWORD="YOUR_DB_PASSWORD"
POSTGRES_DB="adncapital"

# -- AUTH --
NEXTAUTH_URL="https://adncapital.com.vn"
NEXTAUTH_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"
AUTH_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"
# Needed when running behind reverse proxy / local host mismatch
AUTH_TRUST_HOST="true"

# -- GOOGLE OAUTH --
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# -- AI ROUTER / AIDEN --
# 9Router is the primary AIDEN provider. OpenRouter is secondary fallback, Gemini is final fallback.
# If 9Router runs as a local proxy, set the base URL to the gateway that the web runtime can reach.
NINEROUTER_API_KEY=""
NINEROUTER_BASE_URL="http://127.0.0.1:20128/v1"
NINEROUTER_MODEL="ADN-COMBO"
NINEROUTER_PRO_MODEL="ADN-COMBO"
NINEROUTER_AIDEN_MODEL="AIDENfast"
AI_ROUTER_TIMEOUT_MS=45000
AIDEN_CHAT_TIMEOUT_MS=25000
# OpenRouter is optional secondary fallback.
OPENROUTER_API_KEY="REPLACE_WITH_OPENROUTER_API_KEY"
OPENROUTER_MODEL="openai/gpt-4o-mini"
OPENROUTER_PRO_MODEL="openai/gpt-4o-mini"
OPENROUTER_SITE_URL="https://adncapital.com.vn"
OPENROUTER_APP_NAME="ADN Capital"
# Gemini stays as final fallback.
GEMINI_API_KEY="REPLACE_WITH_GEMINI_API_KEY"

# -- AIDEN WEBCHAT: chọn backend để so sánh độ "native" --
# Công tắc cho webchat AIDEN (/api/chat/stream): 9router (mặc định) | freemodel | gemini.
# Đổi giá trị rồi gửi lại câu hỏi để so trực tiếp xem backend nào trả lời tự nhiên nhất.
# Provider đang dùng được trả về trong SSE "meta".provider và log "[AIDEN chat] provider=...".
AIDEN_CHAT_PROVIDER="9router"
# Nhiệt độ câu chữ webchat (0–2). Cao hơn 0.2 cho tự nhiên; số liệu vẫn khóa bằng context.
AIDEN_CHAT_TEMPERATURE="0.6"
# provider=gemini dùng Gemini Flash 3 (gemini-3-flash-preview). Đổi sang gemini-2.5-flash để đối chiếu.
# LƯU Ý: provider=gemini yêu cầu DISABLE_DIRECT_GEMINI KHÔNG bật (xem chống rò phí Gemini bên dưới).
AIDEN_GEMINI_MODEL="gemini-3-flash-preview"
# provider=freemodel (API tương thích OpenAI). Cần key riêng của freemodel.dev.
FREEMODEL_API_KEY=""
FREEMODEL_OPENAI_BASE_URL="https://api.freemodel.dev/v1"
AIDEN_FREEMODEL_MODEL="gpt-5.4"
# Chống rò phí Gemini: đặt "true" để CHẶN mọi lần gọi Gemini trực tiếp (prod, vd crawler).
DISABLE_DIRECT_GEMINI="true"
# Cho phép RIÊNG webchat AIDEN dùng Gemini trực tiếp dù DISABLE_DIRECT_GEMINI bật.
# Đây là lựa chọn chủ đích cho provider=gemini; các path khác vẫn bị cờ trên chặn.
AIDEN_ALLOW_DIRECT_GEMINI="true"

# -- BRIDGE / DATA SOURCES --
# Canonical bridge variable:
PYTHON_BRIDGE_URL="http://fiinquant:8000"
# Backward-compat alias only:
FIINQUANT_URL=""
FIINQUANT_USER="your_fiinquant_email@example.com"
FIINQUANT_PASS="your_fiinquant_password"
VNSTOCK_BRIDGE_URL=""
VNSTOCK_API_KEY=""

# -- TELEGRAM BOT --
TELEGRAM_BOT_TOKEN="REPLACE_WITH_TELEGRAM_BOT_TOKEN"
TELEGRAM_CHAT_ID="REPLACE_WITH_TELEGRAM_CHAT_ID"

# -- PAYOS --
PAYOS_CLIENT_ID="xxx"
PAYOS_API_KEY="xxx"
PAYOS_CHECKSUM_KEY="xxx"

# -- ADMIN / CRON --
ADMIN_EMAILS="admin@adncapital.com.vn"
CRON_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"

# -- APP CONFIG --
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://adncapital.com.vn"
GUIDE_UPLOAD_DIR="/app/storage/guides"
ADN_APP_MIN_SUPPORTED_VERSION="1.0.0"
ADN_ANDROID_APK_URL=""
ADN_ANDROID_APK_SHA256=""

# -- DNSE --
DNSE_API_KEY="REPLACE_WITH_DNSE_API_KEY"
DNSE_TRADING_BASE_URL="https://openapi.dnse.com.vn"
DNSE_TRADING_ACCOUNTS_URL=""
DNSE_MARKET_SNAPSHOT_URL="http://fiinquant:8000/api/v1/market-snapshot"
DNSE_TOKEN_ENCRYPTION_KEY="REPLACE_WITH_LONG_RANDOM_SECRET"
DNSE_BROKER_ACCOUNT_PROFILE_URL=""
DNSE_BROKER_BALANCE_URL=""
DNSE_BROKER_HOLDINGS_URL=""
DNSE_BROKER_POSITIONS_URL=""
DNSE_BROKER_ORDERS_URL=""
DNSE_BROKER_ACCOUNTS_URL=""
DNSE_BROKER_ORDER_HISTORY_URL=""
DNSE_BROKER_LOAN_PACKAGES_URL=""
DNSE_BROKER_PPSE_URL=""
DNSE_EXECUTION_MODE="SAFE_EXECUTION_ADAPTER_MODE"
DNSE_ORDER_INTENT_ENABLED="true"
DNSE_ORDER_PREVIEW_ENABLED="true"
DNSE_REAL_ORDER_SUBMIT_ENABLED="false"
DNSE_MANUAL_TEST_TOKEN_MODE="false"
# Compliance gate: real submit is blocked unless explicitly approved
DNSE_COMPLIANCE_APPROVED_FLOW="false"
# Production hard guards (must stay false by default)
DNSE_ALLOW_REAL_SUBMIT_IN_PROD="false"
DNSE_ALLOW_MANUAL_TEST_IN_PROD="false"
DNSE_EXECUTION_KILL_SWITCH="false"
DNSE_EXECUTION_KILL_SWITCH_REASON=""
DNSE_EXECUTION_ALLOWLIST_ENFORCED="true"
DNSE_EXECUTION_ALLOWLIST_USER_IDS=""
DNSE_EXECUTION_ALLOWLIST_ACCOUNT_IDS=""
DNSE_EXECUTION_ALLOWLIST_EMAILS=""
DNSE_ENFORCE_MARKET_SESSION_GUARD="true"
DNSE_DUPLICATE_SUBMIT_WINDOW_MS="30000"
DNSE_MAX_ORDER_NOTIONAL="500000000"
DNSE_ORDER_REPLAY_COOLDOWN_MS="12000"
DNSE_ORDER_SUBMIT_URL=""
DNSE_MANUAL_TEST_JWT_TOKEN=""
DNSE_MANUAL_TEST_TRADING_TOKEN=""

# -- ADN STOCK CHART: nến intraday real-time từ DNSE (ohlc.1m.json) --
# Bật thu nến 1m thật từ DNSE WS vào v2 (market.ohlcv.intraday.1m, source=dnse_ws) + merge vào chart.
# MẶC ĐỊNH false: deploy là no-op (chart intraday vẫn chạy bằng bridge như cũ). Bật để có nến hôm nay tươi.
# CHART_INTRADAY_DNSE_ENABLED="false"
# CHART_INTRADAY_BARS_TTL_DAYS="3"          # số ngày giữ nến 1m trong v2 (tự prune qua expiresAt)
# CHART_ACTIVE_TICKER_LIMIT="120"           # số mã đang xem chart tối đa được thu nến 1m
# CHART_ACTIVE_TICKER_TTL_MS="1800000"      # 30 phút: mã hết xem thì ngừng thu
# CHART_INTRADAY_WS_TIMEOUT_MS="30000"      # thời lượng 1 phiên WS thu ohlc.1m (chạy song song phiên tick)
