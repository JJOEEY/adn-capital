# ============================================
# ADN Capital - Environment Variables Template
# Usage: cp .env.example .env
# ============================================

# -- DATABASE (PostgreSQL Docker) --
# DATABASE_URL runs through PgBouncer for pooled app traffic
DATABASE_URL="postgresql://adnuser:YOUR_DB_PASSWORD@pgbouncer:5432/adncapital?schema=public&pgbouncer=true"
# DIRECT_DATABASE_URL is for migrate/introspection/direct queries
DIRECT_DATABASE_URL="postgresql://adnuser:YOUR_DB_PASSWORD@db:5432/adncapital?schema=public"

POSTGRES_USER="adnuser"
POSTGRES_PASSWORD="YOUR_DB_PASSWORD"
POSTGRES_DB="adncapital"

# -- AUTH --
NEXTAUTH_URL="https://adncapital.com.vn"
NEXTAUTH_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"
AUTH_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"

# -- GOOGLE OAUTH --
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# -- GEMINI --
GEMINI_API_KEY="REPLACE_WITH_GEMINI_API_KEY"

# -- BRIDGE / DATA SOURCES --
# Canonical bridge variable:
PYTHON_BRIDGE_URL="http://fiinquant:8000"
# Backward-compat alias only:
FIINQUANT_URL=""
FIINQUANT_USER="your_fiinquant_email@example.com"
FIINQUANT_PASS="your_fiinquant_password"
VNSTOCK_BRIDGE_URL=""
VNSTOCK_API_KEY=""

# -- TELEGRAM BOT --
TELEGRAM_BOT_TOKEN="REPLACE_WITH_TELEGRAM_BOT_TOKEN"
TELEGRAM_CHAT_ID="REPLACE_WITH_TELEGRAM_CHAT_ID"

# -- PAYOS --
PAYOS_CLIENT_ID="xxx"
PAYOS_API_KEY="xxx"
PAYOS_CHECKSUM_KEY="xxx"

# -- ADMIN / CRON --
ADMIN_EMAILS="admin@adncapital.com.vn"
CRON_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"

# -- APP CONFIG --
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://adncapital.com.vn"
GUIDE_UPLOAD_DIR="/app/storage/guides"

# -- DNSE --
DNSE_API_KEY="REPLACE_WITH_DNSE_API_KEY"
DNSE_MARKET_SNAPSHOT_URL=""
