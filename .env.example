# ============================================
# ADN Capital - Environment Variables Template
# Hướng dẫn: cp .env.example .env
#             nano .env  (điền giá trị thật)
# ============================================

# ── DATABASE (PostgreSQL Docker) ──────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Khi chạy Docker Compose, HOST là "db" (tên service)
DATABASE_URL="postgresql://adnuser:MAT_KHAU_CUA_BAN@db:5432/adncapital?schema=public"

# Biến môi trường cho Docker Compose (db service)
POSTGRES_USER="adnuser"
POSTGRES_PASSWORD="MAT_KHAU_CUA_BAN"
POSTGRES_DB="adncapital"

# ── NEXTAUTH / AUTH ────────────────────────
NEXTAUTH_URL="https://adncapital.com.vn"
NEXTAUTH_SECRET="THAY_BANG_RANDOM_SECRET_DU_DAI"
AUTH_SECRET="THAY_BANG_RANDOM_SECRET_DU_DAI"

# ── GOOGLE OAUTH ──────────────────────────
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# ── GEMINI AI ─────────────────────────────
GEMINI_API_KEY="AIzaSy..."

# ── FIINQUANT BRIDGE ──────────────────────
# Khi chạy Docker Compose, dùng tên service "fiinquant"
FIINQUANT_URL="http://fiinquant:8000"
FIINQUANT_USER="email@fiinquant.com"
FIINQUANT_PASS="mat_khau_fiinquant"

# ── TELEGRAM BOT ──────────────────────────
TELEGRAM_BOT_TOKEN="8xxx:AAF..."
TELEGRAM_CHAT_ID="-100xxx"

# ── PAYOS PAYMENT ─────────────────────────
PAYOS_CLIENT_ID="xxx"
PAYOS_API_KEY="xxx"
PAYOS_CHECKSUM_KEY="xxx"

# ── ADMIN ─────────────────────────────────
ADMIN_EMAILS="admin@adncapital.com.vn"
CRON_SECRET="THAY_BANG_RANDOM_SECRET"

# ── APP CONFIG ────────────────────────────
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://adncapital.com.vn"
