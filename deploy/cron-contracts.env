# Canonical cron names
CRON_SIGNAL_TYPE1=signal_scan_type1
CRON_MARKET_TYPE2=market_stats_type2
CRON_MORNING=morning_brief
CRON_CLOSE_15H=close_brief_15h
CRON_EOD_19H=eod_full_19h
CRON_NEWS_CRAWLER=news_crawler

# Canonical UTC schedules (VN=UTC+7, Mon-Fri)
CRON_MORNING_SCHEDULE="0 1 * * *"
CRON_SIGNAL_1000_SCHEDULE="0 3 * * 1-5"
CRON_SIGNAL_1030_SCHEDULE="30 3 * * 1-5"
CRON_SIGNAL_1400_SCHEDULE="0 7 * * 1-5"
CRON_SIGNAL_1425_SCHEDULE="25 7 * * 1-5"
CRON_MARKET_1000_SCHEDULE="0 3 * * *"
CRON_MARKET_1130_SCHEDULE="30 4 * * *"
CRON_MARKET_1400_SCHEDULE="0 7 * * *"
CRON_MARKET_1445_SCHEDULE="45 7 * * *"
CRON_CLOSE_15H_SCHEDULE="0 8 * * *"
CRON_EOD_19H_SCHEDULE="0 12 * * *"
CRON_NEWS_CRAWLER_SCHEDULE="*/30 0-15 * * *"
