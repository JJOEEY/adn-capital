# Copy to /home/adncapital/secrets/openclaw-ceo.env on the VPS.
# Keep permission 600. Never commit real values.

OPENCLAW_EXPECTED_TELEGRAM_USERNAME=adnn8n_bot
TELEGRAM_BOT_TOKEN=

OPENCLAW_PROJECT_DIR=/home/adncapital/openclaw-ceo-agent
OPENCLAW_SETUP_PORT=51789
OPENCLAW_GATEWAY_PORT=18790
NINE_ROUTER_PORT=20128

# Persistent runner for the current @adnn8n_bot service.
# Do not use "doctor" here; doctor is only a one-shot health check.
OPENCLAW_CEO_COMMAND='node /opt/openclaw-ceo/release/openclaw.mjs --profile adn-ceo gateway run --bind lan --port 18790 --verbose'

ADN_WEB_HEALTH_URL=http://127.0.0.1:3000/api/health
OPENCLAW_HEALTH_URL=http://127.0.0.1:18790/healthz
NINE_ROUTER_HEALTH_URL=http://127.0.0.1:20128/
OPENCLAW_SETUP_HEALTH_URL=http://127.0.0.1:51789/

OPENCLAW_RAM_RESTART_MB=900
OPENCLAW_RAM_STOP_MB=1200
OPENCLAW_RESTART_COOLDOWN_SEC=600
OPENCLAW_MIN_FREE_DISK_GB=5

# Optional smoke chat. Leave empty unless you want deploy smoke to send a Telegram message.
TELEGRAM_SMOKE_CHAT_ID=

# Optional channels/plugins managed by openclaw-setup dashboard.
ZALO_BOT_TOKEN=
ZALO_PERSONAL_ENABLED=false
FACEBOOK_CRAWLER_ENABLED=false
FACEBOOK_POSTER_ENABLED=false
GITLAWB_API_KEY=

# Optional router/model keys used by the OpenClaw project.
FREEMODEL_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
